<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:gravity="left"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:background="#906C6C"
        tools:srcCompat="@drawable/ic_launcher_foreground" />

    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ContactNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nimi"
            android:textAlignment="center"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/ContactNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PuhelinNro"
            android:textAlignment="center"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/ContactGroupText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ryhmä"
            android:textAlignment="center"
            android:textSize="10sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ContactDetailsButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#354A8E"
        app:srcCompat="@drawable/outline_chat_info_24" />

    <ImageView
        android:id="@+id/ContactDeleteButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#E91E43"
        app:srcCompat="@drawable/outline_delete_24" />

</LinearLayout>